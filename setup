#!/usr/bin/env bash
# Set up ninthwave in a project directory.
#
# Usage:
#   ~/.claude/skills/ninthwave/setup                    # from project dir
#   ~/.claude/skills/ninthwave/setup --project-dir /path/to/project
#
# Creates project-level config and skill discovery symlinks.
# All artifacts are project-level (committed to git) so every team member
# gets them via git pull. No per-user setup needed.
#
# Dependencies (per-user, not installed by this script):
#   - An AI coding tool (Claude Code, OpenCode, Copilot CLI, etc.)
#   - cmux (for parallel sessions)
#   - gh (for PR operations)

set -euo pipefail

NINTHWAVE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v bun &>/dev/null; then
  echo "Warning: bun is required for ninthwave. Install: curl -fsSL https://bun.sh/install | bash"
fi

# Defaults
PROJECT_DIR=""

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --project-dir) PROJECT_DIR="$2"; shift 2 ;;
    -h|--help)
      echo "Usage: $0 [--project-dir /path/to/project]"
      echo
      echo "Sets up ninthwave in the project. Creates config, CLI shim,"
      echo "skill symlinks, and agent files. All project-level."
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# Default to current directory
PROJECT_DIR="${PROJECT_DIR:-$(pwd)}"

# Verify it's a git repo
if [[ ! -d "$PROJECT_DIR/.git" ]]; then
  echo "Error: $PROJECT_DIR is not a git repository"
  exit 1
fi

echo "Setting up ninthwave in: $PROJECT_DIR"
echo "Bundle location: $NINTHWAVE_DIR"
echo

# --- .ninthwave/ config ---

echo "Config (.ninthwave/)..."

mkdir -p "$PROJECT_DIR/.ninthwave"

# Record the bundle location
echo "$NINTHWAVE_DIR" > "$PROJECT_DIR/.ninthwave/dir"
echo "  .ninthwave/dir"

# Create the CLI shim
# Clean up old shim name
rm -f "$PROJECT_DIR/.ninthwave/nw"

cat > "$PROJECT_DIR/.ninthwave/work" << 'SHIM'
#!/usr/bin/env bash
exec bun run "$(cat "$(dirname "$0")/dir")/core/cli.ts" "$@"
SHIM
chmod +x "$PROJECT_DIR/.ninthwave/work"
echo "  .ninthwave/work"

if [[ ! -f "$PROJECT_DIR/.ninthwave/config" ]]; then
  cat > "$PROJECT_DIR/.ninthwave/config" << 'CONF'
# ninthwave project configuration
# All settings are optional -- sensible defaults are used.

# File extensions for LOC counting in version-bump (space-separated glob patterns)
# LOC_EXTENSIONS="*.ts *.tsx *.js *.jsx *.py *.go"

# Path to domain mapping file (optional)
# DOMAINS_FILE=.ninthwave/domains.conf
CONF
  echo "  .ninthwave/config (created)"
else
  echo "  .ninthwave/config (exists, skipped)"
fi

if [[ ! -f "$PROJECT_DIR/.ninthwave/domains.conf" ]]; then
  cat > "$PROJECT_DIR/.ninthwave/domains.conf" << 'DOMAINS'
# Domain mappings for ninthwave
# Format: pattern=domain_key
# Patterns are matched case-insensitively against section headers in TODOS.md.
# Lines starting with # are comments.
#
# Examples:
# auth=auth
# infrastructure=infra
# frontend=frontend
# database=db
DOMAINS
  echo "  .ninthwave/domains.conf (created)"
else
  echo "  .ninthwave/domains.conf (exists, skipped)"
fi

echo

# --- TODOS.md ---

if [[ ! -f "$PROJECT_DIR/TODOS.md" ]]; then
  cat > "$PROJECT_DIR/TODOS.md" << 'EOF'
# TODOS

<!-- Format guide: see $(cat .ninthwave/dir)/core/docs/todos-format.md -->
EOF
  echo "TODOS.md (created)"
else
  echo "TODOS.md (exists, skipped)"
fi

echo

# --- Skill discovery symlinks ---

echo "Skills..."

# Determine the skills directory for symlinks
# Per-project: .claude/skills/ in the project
# Global: ~/.claude/skills/ (NINTHWAVE_DIR is already there)
if [[ "$NINTHWAVE_DIR" == "$HOME/.claude/skills/ninthwave" ]]; then
  SKILLS_DIR="$HOME/.claude/skills"
  LINK_TARGET="ninthwave/skills"
elif [[ "$NINTHWAVE_DIR" == "$PROJECT_DIR/.claude/skills/ninthwave" ]] || \
     [[ "$(cd "$NINTHWAVE_DIR" 2>/dev/null && pwd)" == "$(cd "$PROJECT_DIR/.claude/skills/ninthwave" 2>/dev/null && pwd)" ]]; then
  SKILLS_DIR="$PROJECT_DIR/.claude/skills"
  LINK_TARGET="ninthwave/skills"
else
  # Custom location -- use absolute paths
  SKILLS_DIR="$PROJECT_DIR/.claude/skills"
  LINK_TARGET="$NINTHWAVE_DIR/skills"
fi

mkdir -p "$SKILLS_DIR"

for skill in work decompose todo-preview ninthwave-upgrade; do
  # Only create symlink if the skill exists in the bundle
  if [[ -d "$NINTHWAVE_DIR/skills/$skill" ]]; then
    rm -f "$SKILLS_DIR/$skill"
    ln -s "$LINK_TARGET/$skill" "$SKILLS_DIR/$skill"
    echo "  .claude/skills/$skill -> $LINK_TARGET/$skill"
  fi
done

echo

# --- Agent files (copied, not symlinked -- must be in tool-specific dirs) ---

echo "Agents..."

mkdir -p "$PROJECT_DIR/.claude/agents"
cp "$NINTHWAVE_DIR/agents/todo-worker.md" "$PROJECT_DIR/.claude/agents/todo-worker.md"
echo "  .claude/agents/todo-worker.md"

mkdir -p "$PROJECT_DIR/.opencode/agents"
cp "$NINTHWAVE_DIR/agents/todo-worker.md" "$PROJECT_DIR/.opencode/agents/todo-worker.md"
echo "  .opencode/agents/todo-worker.md"

mkdir -p "$PROJECT_DIR/.github/agents"
cp "$NINTHWAVE_DIR/agents/todo-worker.md" "$PROJECT_DIR/.github/agents/todo-worker.agent.md"
echo "  .github/agents/todo-worker.agent.md"

echo

# --- .gitignore ---

if [[ -f "$PROJECT_DIR/.gitignore" ]]; then
  if ! grep -q "^\.worktrees/" "$PROJECT_DIR/.gitignore" 2>/dev/null; then
    echo "" >> "$PROJECT_DIR/.gitignore"
    echo "# ninthwave worktrees" >> "$PROJECT_DIR/.gitignore"
    echo ".worktrees/" >> "$PROJECT_DIR/.gitignore"
    echo ".gitignore (added .worktrees/)"
  fi
else
  cat > "$PROJECT_DIR/.gitignore" << 'GITIGNORE'
# ninthwave worktrees
.worktrees/
GITIGNORE
  echo ".gitignore (created)"
fi

echo

# --- Version tracking ---

local_version="$(cd "$NINTHWAVE_DIR" && git describe --tags --always 2>/dev/null || echo "unknown")"
echo "$local_version" > "$PROJECT_DIR/.ninthwave/version"

# --- Summary ---

echo "Done! All files are project-level (commit to git)."
echo
echo "Next steps:"
echo "  1. Review: git diff"
echo "  2. Commit: git add -A && git commit -m 'chore: set up ninthwave'"
echo "  3. Add work items to TODOS.md and run /work"
echo
echo "Per-user dependencies (each team member installs once):"
command -v gh &>/dev/null      && echo "  gh:     installed" || echo "  gh:     https://cli.github.com/"
command -v cmux &>/dev/null    && echo "  cmux:   installed" || echo "  cmux:   https://cmux.com/"
echo
echo "Update ninthwave anytime with /ninthwave-upgrade"
