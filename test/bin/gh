#!/usr/bin/env bun

import { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from "fs";
import { dirname, join } from "path";
import { spawnSync } from "child_process";

interface FakeCheckRun {
  state: string;
  name: string;
  link: string;
  completedAt?: string;
}

interface FakePrRecord {
  number: number;
  branch: string;
  state: "open" | "merged";
  title: string;
  body: string;
  createdAt: string;
  updatedAt: string;
  headSha: string;
  mergeable: "MERGEABLE" | "CONFLICTING";
  reviewDecision: string;
  checks: FakeCheckRun[];
  baseRefName: string;
  mergeCommitSha?: string;
}

interface FakeGhState {
  nextPrNumber: number;
  prs: FakePrRecord[];
}

const args = process.argv.slice(2);
const repoRoot = process.cwd();
const statePath = process.env.NINTHWAVE_FAKE_GH_STATE_PATH
  ?? join(repoRoot, ".ninthwave", "test-system", "fake-gh.json");
const repoNameWithOwner = process.env.NINTHWAVE_FAKE_GH_REPO ?? "ninthwave-sh/test-system";
const defaultBranch = process.env.NINTHWAVE_FAKE_GH_DEFAULT_BRANCH ?? "main";
const autoCreatePrs = process.env.NINTHWAVE_FAKE_GH_AUTO_CREATE_PRS !== "0";

function fail(message: string): never {
  console.error(message);
  process.exit(1);
}

function git(...gitArgs: string[]): string {
  const result = spawnSync("git", ["-C", repoRoot, ...gitArgs], {
    encoding: "utf-8",
    stdio: ["pipe", "pipe", "pipe"],
  });
  if (result.status !== 0) {
    fail(result.stderr || `git ${gitArgs.join(" ")} failed`);
  }
  return (result.stdout || "").trim();
}

function loadState(): FakeGhState {
  if (!existsSync(statePath)) {
    return { nextPrNumber: 1, prs: [] };
  }
  return JSON.parse(readFileSync(statePath, "utf-8")) as FakeGhState;
}

function saveState(state: FakeGhState): void {
  mkdirSync(dirname(statePath), { recursive: true });
  writeFileSync(statePath, JSON.stringify(state, null, 2) + "\n", "utf-8");
}

function branchExists(branch: string): boolean {
  const result = spawnSync("git", ["-C", repoRoot, "show-ref", "--verify", "--quiet", `refs/heads/${branch}`], {
    stdio: "ignore",
  });
  return result.status === 0;
}

function workItemMetadata(branch: string): { title: string; body: string } {
  const itemId = branch.replace(/^ninthwave\//, "");
  const workDir = join(repoRoot, ".ninthwave", "work");
  if (!existsSync(workDir)) {
    return {
      title: `test: ${itemId}`,
      body: `## Work Item Reference\nID: ${itemId}\n`,
    };
  }

  const filename = readdirSync(workDir).find((entry) => entry.endsWith(`--${itemId}.md`));
  if (!filename) {
    return {
      title: `test: ${itemId}`,
      body: `## Work Item Reference\nID: ${itemId}\n`,
    };
  }

  const content = readFileSync(join(workDir, filename), "utf-8");
  const title = content.match(/^#\s+(.+)$/m)?.[1]?.trim() ?? `test: ${itemId}`;
  const lineage = content.match(/^\*\*Lineage:\*\*\s+(.+)$/m)?.[1]?.trim();

  return {
    title,
    body: [
      "## Work Item Reference",
      `ID: ${itemId}`,
      ...(lineage ? [`Lineage: ${lineage}`] : []),
    ].join("\n"),
  };
}

function ensurePrRecord(state: FakeGhState, branch: string): FakePrRecord | undefined {
  const existing = state.prs.find((entry) => entry.branch === branch);
  if (existing) {
    if (branchExists(branch)) {
      existing.headSha = git("rev-parse", branch);
      existing.updatedAt = new Date().toISOString();
    }
    return existing;
  }

  if (!branch.startsWith("ninthwave/") || !branchExists(branch)) return undefined;

  const now = new Date().toISOString();
  const metadata = workItemMetadata(branch);
  const record: FakePrRecord = {
    number: state.nextPrNumber++,
    branch,
    state: "open",
    title: metadata.title,
    body: metadata.body,
    createdAt: now,
    updatedAt: now,
    headSha: git("rev-parse", branch),
    mergeable: "MERGEABLE",
    reviewDecision: "",
    checks: [
      {
        state: "SUCCESS",
        name: "test",
        link: "https://example.invalid/checks/test",
        completedAt: now,
      },
    ],
    baseRefName: defaultBranch,
  };
  state.prs.push(record);
  return record;
}

function printJson(value: unknown): void {
  console.log(JSON.stringify(value));
}

function handleRepoView(): void {
  const jsonFields = args[args.indexOf("--json") + 1] ?? "";
  const jq = args.includes("--jq") ? args[args.indexOf("--jq") + 1] : undefined;

  if (jq === ".nameWithOwner") {
    console.log(repoNameWithOwner);
    return;
  }

  const response: Record<string, unknown> = {};
  for (const field of jsonFields.split(",").filter(Boolean)) {
    if (field === "nameWithOwner") response.nameWithOwner = repoNameWithOwner;
    if (field === "defaultBranchRef") response.defaultBranchRef = { name: defaultBranch };
  }
  printJson(response);
}

function handlePrList(): void {
  const state = loadState();
  const head = args[args.indexOf("--head") + 1] ?? "";
  const desiredState = args[args.indexOf("--state") + 1] ?? "open";
  const record = autoCreatePrs
    ? ensurePrRecord(state, head)
    : state.prs.find((entry) => entry.branch === head);
  saveState(state);

  if (!record || record.state !== desiredState) {
    printJson([]);
    return;
  }

  printJson([{ number: record.number, title: record.title, body: record.body }]);
}

function handlePrView(): void {
  const state = loadState();
  const prNumber = parseInt(args[2] ?? "0", 10);
  const fields = (args[args.indexOf("--json") + 1] ?? "").split(",").filter(Boolean);
  const record = state.prs.find((entry) => entry.number === prNumber);
  if (!record) fail(`PR #${prNumber} not found`);

  const response: Record<string, unknown> = {};
  for (const field of fields) {
    switch (field) {
      case "reviewDecision":
        response.reviewDecision = record.reviewDecision;
        break;
      case "mergeable":
        response.mergeable = record.mergeable;
        break;
      case "updatedAt":
        response.updatedAt = record.updatedAt;
        break;
      case "createdAt":
        response.createdAt = record.createdAt;
        break;
      case "headRefOid":
        response.headRefOid = record.headSha;
        break;
      case "baseRefName":
        response.baseRefName = record.baseRefName;
        break;
      case "mergeCommit":
        response.mergeCommit = record.mergeCommitSha ? { oid: record.mergeCommitSha } : null;
        break;
      case "state":
        response.state = record.state === "merged" ? "MERGED" : "OPEN";
        break;
    }
  }
  printJson(response);
}

function handlePrChecks(): void {
  const state = loadState();
  const prNumber = parseInt(args[2] ?? "0", 10);
  const record = state.prs.find((entry) => entry.number === prNumber);
  if (!record) fail(`PR #${prNumber} not found`);
  printJson(record.checks);
}

function handlePrMerge(): void {
  const state = loadState();
  const prNumber = parseInt(args[2] ?? "0", 10);
  const record = state.prs.find((entry) => entry.number === prNumber);
  if (!record) fail(`PR #${prNumber} not found`);

  const mergeSha = git("rev-parse", record.branch);
  record.state = "merged";
  record.mergeCommitSha = mergeSha;
  record.updatedAt = new Date().toISOString();
  saveState(state);
}

function handleLabelCreate(): void {
  // No-op: domain labels are best-effort in tests.
}

function handleApi(): void {
  const path = args.find((arg) => arg.startsWith("repos/")) ?? "";
  const jq = args.includes("--jq") ? args[args.indexOf("--jq") + 1] ?? "" : "";

  if (path.endsWith("/check-runs")) {
    printJson([
      { name: "test", status: "completed", conclusion: "success" },
    ]);
    return;
  }

  if (jq.includes("| length")) {
    console.log("0");
    return;
  }

  printJson([]);
}

function handlePrComment(): void {
  // No-op in the happy-path system tests.
}

function handlePrEdit(): void {
  // No-op in the happy-path system tests.
}

if (args.length === 0) fail("gh stub requires arguments");

if (args[0] === "--version") {
  console.log("gh version 0.0.0-test");
  process.exit(0);
}

if (args[0] === "repo" && args[1] === "view") {
  handleRepoView();
  process.exit(0);
}

if (args[0] === "label" && args[1] === "create") {
  handleLabelCreate();
  process.exit(0);
}

if (args[0] === "pr" && args[1] === "list") {
  handlePrList();
  process.exit(0);
}

if (args[0] === "pr" && args[1] === "view") {
  handlePrView();
  process.exit(0);
}

if (args[0] === "pr" && args[1] === "checks") {
  handlePrChecks();
  process.exit(0);
}

if (args[0] === "pr" && args[1] === "merge") {
  handlePrMerge();
  process.exit(0);
}

if (args[0] === "pr" && args[1] === "comment") {
  handlePrComment();
  process.exit(0);
}

if (args[0] === "pr" && args[1] === "edit") {
  handlePrEdit();
  process.exit(0);
}

if (args[0] === "api") {
  handleApi();
  process.exit(0);
}

fail(`Unsupported gh invocation: ${args.join(" ")}`);
