# ninthwave worktrees
.worktrees/

# Machine-specific bundle location (created by setup)
.ninthwave/dir

# Legacy CLI shim (no longer created by setup)
.ninthwave/work

# Claude Code per-user data (created in worktrees by workers)
.claude/projects/

# Node/Bun dependencies
node_modules/

# Build artifacts
dist/

# GitHub Actions require compiled dist to be committed
!actions/*/dist/

# Rust build artifacts (validation projects)
validation/*/target/
